  "content": [
    {
      "level": 1,
      "style": {},
      "text": "\u519c\u573a\u79cd\u690d\u7ba1\u7406\u7cfb\u7edf\u5b9e\u9a8c\u62a5\u544a",
      "type": "heading"
    },
    {
      "level": 2,
      "style": {},
      "text": "\u4e00\u3001\u5b9e\u9a8c\u76ee\u7684\u53ca\u8981\u6c42",
      "type": "heading"
    },
    {
      "style": {},
      "text": "\u672c\u5b9e\u9a8c\u65e8\u5728\u901a\u8fc7\u5f00\u53d1\u4e00\u4e2a\u5b8c\u6574\u7684\u519c\u573a\u79cd\u690d\u7ba1\u7406\u7cfb\u7edf\uff0c\u7efc\u5408\u8fd0\u7528Java Web\u5f00\u53d1\u6280\u672f\u6808\uff0c\u5b9e\u73b0\u4ece\u6570\u636e\u5e93\u8bbe\u8ba1\u5230\u524d\u540e\u7aef\u4ea4\u4e92\u7684\u5168\u6d41\u7a0b\u5f00\u53d1\u3002\u5177\u4f53\u76ee\u6807\u5982\u4e0b\uff1a",
      "type": "paragraph"
    },
    {
      "style": {},
      "text": "\uff081\uff09\u638c\u63e1Spring Boot 3\u6846\u67b6\u7684\u9879\u76ee\u642d\u5efa\u3001\u81ea\u52a8\u914d\u7f6e\u548cRESTful API\u5f00\u53d1\u65b9\u6cd5\uff0c\u7406\u89e3MVC\u5206\u5c42\u67b6\u6784\u601d\u60f3\u3002",
      "type": "paragraph"
    },
    {
      "style": {},
      "text": "\uff082\uff09\u638c\u63e1JPA\uff08Hibernate\uff09\u4e0ePostgreSQL\u5173\u7cfb\u578b\u6570\u636e\u5e93\u7684\u4ea4\u4e92\u6280\u672f\uff0c\u5305\u62ec\u5b9e\u4f53\u6620\u5c04\u3001\u5173\u8054\u67e5\u8be2\u548c\u4e8b\u52a1\u7ba1\u7406\u3002",
      "type": "paragraph"
    },
    {
      "style": {},
      "text": "\uff083\uff09\u638c\u63e1\u57fa\u4e8eSession\u7684Web\u7528\u6237\u72b6\u6001\u7ba1\u7406\u673a\u5236\uff0c\u5b9e\u73b0\u591a\u7528\u6237\u5207\u6362\u548c\u72b6\u6001\u9694\u79bb\u3002",
      "type": "paragraph"
    },
    {
      "style": {},
      "text": "\uff084\uff09\u638c\u63e1jQuery EasyUI\u524d\u7aef\u6846\u67b6\u7684\u4f7f\u7528\uff0c\u5305\u62ecDataGrid\u6570\u636e\u8868\u683c\u3001Dialog\u5bf9\u8bdd\u6846\u3001Combobox\u4e0b\u62c9\u6846\u7b49\u7ec4\u4ef6\u7684\u96c6\u6210\u5e94\u7528\u3002",
      "type": "paragraph"
    },
    {
      "style": {},
      "text": "\uff086\uff09\u5b8c\u6210\u4e00\u4e2a\u754c\u9762\u7f8e\u89c2\u3001\u529f\u80fd\u5b8c\u6574\u3001\u6570\u636e\u6301\u4e45\u5316\u7684\u519c\u573a\u79cd\u690d\u7ba1\u7406\u7cfb\u7edf\uff0c\u5b9e\u73b0\u4ece\u79cd\u5b50\u8d2d\u4e70\u3001\u519c\u573a\u64ad\u79cd\u3001\u751f\u957f\u7ba1\u7406\u5230\u6536\u83b7\u7684\u5168\u95ed\u73af\u4e1a\u52a1\u6d41\u7a0b\u3002",
      "type": "paragraph"
    },
    {
      "level": 2,
      "style": {},
      "text": "\u4e8c\u3001\u5b9e\u9a8c\u4eea\u5668\u8bbe\u5907",
      "type": "heading"
    },
    {
      "style": {},
      "text": "\u672c\u5b9e\u9a8c\u4f7f\u7528\u7684\u786c\u4ef6\u548c\u8f6f\u4ef6\u73af\u5883\u5982\u4e0b\u8868\u6240\u793a\uff1a",
      "type": "paragraph"
    },
